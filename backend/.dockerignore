# 后端 .dockerignore - Docker 构建时忽略的文件和目录

# 版本控制
.git/
.gitignore
.gitattributes

# 文档
README.md
*.md

# 环境配置
.env
.env.*

# IDE 配置
.idea/
.vscode/
*.iml
*.ipr
*.iws

# 系统文件
.DS_Store
Thumbs.db

# 日志文件
logs/
*.log

# 临时文件
tmp/
temp/
*.tmp

# Maven 源码相关（保留 target 目录中的 jar 包）
src/
pom.xml
mvnw
mvnw.cmd
.mvn/
