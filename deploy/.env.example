# =====================================
# 家庭管理系统 - 环境变量配置
# 复制此文件为 .env 并修改为实际配置
# =====================================

# ---------- 数据库配置 ----------
POSTGRES_DB=family_app
POSTGRES_USER=family
# 【重要】请修改为强密码
POSTGRES_PASSWORD=your_strong_password_here

# ---------- JWT 配置 ----------
# 【重要】请修改为随机字符串（至少32位）
JWT_SECRET=please_change_this_to_a_long_random_string_2024
JWT_EXPIRE_HOURS=24

# ---------- 百度语音（可选） ----------
# 不使用可留空
BAIDU_SPEECH_APP_ID=
BAIDU_SPEECH_API_KEY=
BAIDU_SPEECH_SECRET_KEY=

# ---------- JVM 参数 ----------
# 根据服务器内存调整，2G内存建议 -Xms256m -Xmx512m
JAVA_OPTS="-Xms256m -Xmx512m"

# ---------- 域名配置（可选） ----------
# 用于 Nginx 和 HTTPS 证书
DOMAIN=your-domain.com
